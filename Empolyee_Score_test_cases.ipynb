    "results = []\n",
    "\n",
    "for case in test_cases:\n",
    "    result = calculate_employee_score(\n",
    "        case[\"data\"],\n",
    "        case[\"gates\"],\n",
    "        case[\"modifiers\"],\n",
    "        case[\"weights\"],\n",
    "    )\n",
    "    results.append({\n",
    "        \"Case ID\":         case[\"case_id\"],\n",
    "        \"Label\":           case[\"label\"],\n",
    "        \"Score\":           result[\"score\"],\n",
    "        \"Gate\":            result[\"gate_result\"],\n",
    "        \"Modifier\":        result[\"modifier\"],\n",
    "        \"X1\":   result[\"x1\"],\n",
    "        \"X2\":   result[\"x2\"],\n",
    "        \"X3\":   result[\"x3\"],\n",
    "        \"X4\":   result[\"x4\"],\n",
    "        \"X5\":   result[\"x5\"],\n",
    "        \"X6\":   result[\"x6\"],\n",
    "        \"X7\":   result[\"x7\"],\n",
    "        \"X8\":   result[\"x8\"],\n",
    "        \"X9\":   result[\"x9\"],\n",
    "        \"X10\":  result[\"x10\"],\n",
    "        \"X11\":  result[\"x11\"],\n",
    "        \"X12\":  result[\"x12\"],\n",
    "        \"Summary\":  case[\"summary\"]\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(results)\n",
    "df_sorted = df.sort_values(\"Score\", ascending=False).reset_index(drop=True)\n",
